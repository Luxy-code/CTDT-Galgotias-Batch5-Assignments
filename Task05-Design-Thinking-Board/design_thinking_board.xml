    <mxCell id="problem_text" value="&lt;b style='font-size:16px; color:#991b1b;'&gt;Ambiguous Problem:&lt;/b&gt;&lt;br&gt;Office workers experience chronic back pain but abandon wearable posture correctors because they are uncomfortable, ugly, and buzz aggressively during important meetings." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontColor=#7f1d1d;spacingLeft=20;" vertex="1" parent="1">
      <mxGeometry x="50" y="110" width="1400" height="80" as="geometry" />
    </mxCell>

    <!-- COLUMN 1: EMPATHIZE -->
    <mxCell id="col1_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#bfdbfe;" vertex="1" parent="1">
      <mxGeometry x="50" y="230" width="260" height="400" as="geometry" />
    </mxCell>
    <mxCell id="col1_title" value="&lt;b style='font-size:18px;'&gt;1. Empathize&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontColor=#1e40af;" vertex="1" parent="1">
      <mxGeometry x="50" y="240" width="260" height="40" as="geometry" />
    </mxCell>
    <mxCell id="col1_content" value="&lt;b&gt;User Interviews:&lt;/b&gt;&lt;br&gt;&quot;I want better posture, but I hate wearing straps under my clothes.&quot;&lt;br&gt;&lt;br&gt;&lt;b&gt;Observations:&lt;/b&gt;&lt;br&gt;People slump forward towards their monitors after exactly 2 hours of deep work.&lt;br&gt;&lt;br&gt;&lt;b&gt;Key Insight:&lt;/b&gt;&lt;br&gt;The solution must be invisible and require zero daily setup from the user." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontColor=#1e293b;spacing=15;" vertex="1" parent="1">
      <mxGeometry x="50" y="290" width="260" height="340" as="geometry" />
    </mxCell>

    <!-- COLUMN 2: DEFINE -->
    <mxCell id="col2_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fdf4ff;strokeColor=#f5d0fe;" vertex="1" parent="1">
      <mxGeometry x="335" y="230" width="260" height="400" as="geometry" />
    </mxCell>
    <mxCell id="col2_title" value="&lt;b style='font-size:18px;'&gt;2. Define&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontColor=#86198f;" vertex="1" parent="1">
      <mxGeometry x="335" y="240" width="260" height="40" as="geometry" />
    </mxCell>
    <mxCell id="col2_content" value="&lt;b&gt;Target Persona:&lt;/b&gt;&lt;br&gt;Remote tech workers sitting 8+ hours a day.&lt;br&gt;&lt;br&gt;&lt;b&gt;Problem Statement (HMW):&lt;/b&gt;&lt;br&gt;&lt;i&gt;&quot;How might we integrate posture correction seamlessly into the office environment so the user doesn't have to wear or remember anything?&quot;&lt;/i&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;Constraints:&lt;/b&gt;&lt;br&gt;Must not disrupt deep work. Must look like standard premium office furniture." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontColor=#1e293b;spacing=15;" vertex="1" parent="1">
      <mxGeometry x="335" y="290" width="260" height="340" as="geometry" />
    </mxCell>

    <!-- COLUMN 3: IDEATE -->
    <mxCell id="col3_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fffbeb;strokeColor=#fde68a;" vertex="1" parent="1">
      <mxGeometry x="620" y="230" width="260" height="400" as="geometry" />
    </mxCell>
    <mxCell id="col3_title" value="&lt;b style='font-size:18px;'&gt;3. Ideate&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontColor=#b45309;" vertex="1" parent="1">
      <mxGeometry x="620" y="240" width="260" height="40" as="geometry" />
    </mxCell>
    <mxCell id="col3_content" value="&lt;b&gt;Brainstorming Ideas:&lt;/b&gt;&lt;br&gt;1. A smart desk that raises when you slump.&lt;br&gt;2. A camera that yells at you (Rejected - creepy).&lt;br&gt;3. &lt;b&gt;Winner:&lt;/b&gt; A smart chair with pressure sensors in the backrest that gently nudges the lumbar support forward when it detects slouching.&lt;br&gt;&lt;br&gt;&lt;b&gt;Features:&lt;/b&gt;&lt;br&gt;- Haptic motor in lumbar.&lt;br&gt;- Bluetooth app integration for health stats." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontColor=#1e293b;spacing=15;" vertex="1" parent="1">
      <mxGeometry x="620" y="290" width="260" height="340" as="geometry" />
    </mxCell>

    <!-- COLUMN 4: PROTOTYPE -->
    <mxCell id="col4_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0fdf4;strokeColor=#bbf7d0;" vertex="1" parent="1">
      <mxGeometry x="905" y="230" width="260" height="400" as="geometry" />
    </mxCell>
    <mxCell id="col4_title" value="&lt;b style='font-size:18px;'&gt;4. Prototype&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontColor=#166534;" vertex="1" parent="1">
      <mxGeometry x="905" y="240" width="260" height="40" as="geometry" />
    </mxCell>
    <mxCell id="col4_content" value="&lt;b&gt;MVP Build:&lt;/b&gt;&lt;br&gt;Modified a standard ergonomic chair.&lt;br&gt;Wired 4 pressure pads into the back mesh.&lt;br&gt;Connected an Arduino to trigger a small vibration motor if the upper sensors lose contact for more than 5 minutes.&lt;br&gt;&lt;br&gt;&lt;b&gt;App Mockup:&lt;/b&gt;&lt;br&gt;Simple dashboard showing &quot;Hours Sat Correctly&quot; and &quot;Slouch Count&quot;." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontColor=#1e293b;spacing=15;" vertex="1" parent="1">
      <mxGeometry x="905" y="290" width="260" height="340" as="geometry" />
    </mxCell>

